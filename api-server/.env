# ===========================================
# TrendRadar Mobile API 配置
# ===========================================

# 应用基础
APP_NAME=TrendRadar Mobile API
DEBUG=true

# JWT 密钥
SECRET_KEY=your-super-secret-key-change-in-production-please

# 数据库
DATABASE_URL=sqlite:///./trendradar.db

# Redis
REDIS_URL=redis://localhost:6379

# ===========================================
# 支付配置 (支付宝当面付)
# ===========================================

# 支付模式: sandbox (沙箱) | production (正式)
PAYMENT_MODE=sandbox

# ---------- 支付宝当面付配置 ----------
ALIPAY_APPID=2021006136661160

# 应用私钥 (RSA2) - 去掉换行
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY----------END RSA PRIVATE KEY-----

# 支付宝公钥 - 去掉换行
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY----------END PUBLIC KEY-----

# 商户门店编号 (当面付必需)
ALIPAY_STORE_ID=ONLINE001

# 异步通知地址 (需要公网可访问)
ALIPAY_NOTIFY_URL=https://trendradar-vip.loca.lt/api/v1/vip/webhook/alipay
