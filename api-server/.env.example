# ===========================================
# TrendRadar Mobile API 配置
# ===========================================

# 应用基础
APP_NAME=TrendRadar Mobile API
DEBUG=true

# JWT 密钥 (请修改为安全的随机字符串)
SECRET_KEY=your-super-secret-key-change-in-production-please

# 数据库
DATABASE_URL=sqlite:///./trendradar.db

# Redis
REDIS_URL=redis://localhost:6379

# ===========================================
# 支付配置 (支付宝当面付)
# ===========================================

# 支付模式: sandbox (沙箱) | production (正式)
PAYMENT_MODE=sandbox

# ---------- 支付宝当面付配置 ----------
# 在支付宝开放平台 https://open.alipay.com 获取

# 应用ID (开放平台->应用详情)
ALIPAY_APPID=your_alipay_appid

# 应用私钥 (RSA2)
# 在开放平台->开发设置->应用密钥中设置
# 格式: -----BEGIN RSA PRIVATE KEY----- ... -----END RSA PRIVATE KEY-----
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_private_key_content_here
-----END RSA PRIVATE KEY-----"

# 支付宝公钥
# 在开放平台->开发设置->应用密钥中获取
# 格式: -----BEGIN PUBLIC KEY----- ... -----END PUBLIC KEY-----
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
your_alipay_public_key_content_here
-----END PUBLIC KEY-----"

# 商户门店编号 (当面付必需)
# 在商户中心->门店管理中添加
ALIPAY_STORE_ID=your_store_id

# 异步通知地址 (需要公网可访问)
# 例如: https://yourdomain.com/api/v1/vip/webhook/alipay
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/v1/vip/webhook/alipay
